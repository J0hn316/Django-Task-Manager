{
  "name": "django-task-manager",
  "version": "1.0.0",
  "description": "A Django web application for managing projects and tasks. Users can create projects, add tasks to each project, update task status and priority, search/filter/sort tasks, view project stats, and run automated tests to verify ownership and behavior.",
  "main": "index.js",
  "scripts": {
  "dev:css": "npx @tailwindcss/cli -i ./src/input.css -o ./tasks/static/tasks/output.css --watch",
  "build:css": "npx @tailwindcss/cli -i ./src/input.css -o ./tasks/static/tasks/output.css --minify"
},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/J0hn316/Django-Task-Manager.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/J0hn316/Django-Task-Manager/issues"
  },
  "homepage": "https://github.com/J0hn316/Django-Task-Manager#readme",
  "dependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "tailwindcss": "^4.3.0"
  }
}
